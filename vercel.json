    {
      "path": "/api/cron/cleanup",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/delay-sweep",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/webhook-cleanup",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/process-communications",
