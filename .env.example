# --- Required ---
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
AI_API_KEY=sk-...                  # LLM provider key (OpenAI-compatible)
AI_BASE_URL=                       # OpenAI-compatible base URL (e.g. DashScope endpoint)
AI_MODEL=                          # chat model id
# --- Optional: GLM (z.ai) for the super-admin model switcher ---
# Configure these to make "GLM-4.6 (z.ai)" selectable in Settings → Integrations
# (super-admin only). If GLM_API_KEY is unset, selecting GLM silently falls back
# to the default model — a customer turn is never broken by a missing key.
GLM_API_KEY=                       # z.ai API key (leave blank to disable GLM)
GLM_BASE_URL=https://api.z.ai/api/paas/v4   # OpenAI-compatible base URL for z.ai
GLM_MODEL=glm-4.6                  # GLM model id
ENCRYPTION_KEY=64-hex-chars-here   # PII encryption + dedupe blind-index HMAC
AUTH_SECRET=generate-a-32-char-random-string-here
CRON_SECRET=generate-a-random-secret-for-cron-auth
NODE_ENV=development

# --- Twilio (phone agent) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SPEECH_TIMEOUT=             # optional, seconds Twilio waits for speech

# --- Voice (optional) ---
ELEVENLABS_API_KEY=                # premium phone TTS; falls back to Polly <Say> if unset
ELEVENLABS_VOICE_ID=               # optional, defaults to "Brian"
ELEVENLABS_MODEL_ID=               # optional, defaults to eleven_turbo_v2_5
VOICE_PROVIDER=                    # optional, force "elevenlabs" or "polly"
TWILIO_VOICE=                      # optional Polly voice override (used only when no ElevenLabs key)

# --- Google (optional) ---
GOOGLE_CLIENT_ID=                  # admin Google sign-in + Calendar integration
GOOGLE_CLIENT_SECRET=
GOOGLE_OIDC_REDIRECT_URI=          # OIDC login callback, e.g. https://app.example.com/api/auth/google/callback
GOOGLE_REDIRECT_URI=               # Calendar OAuth callback

# --- Housecall Pro (optional, integration not yet enabled) ---
HOUSECALL_API_KEY=
HOUSECALL_WEBHOOK_SECRET=

# --- Misc (optional) ---
NEXT_PUBLIC_APP_URL=               # absolute base URL (TTS audio links, widget embed)
AI_EXTRACTION_MODEL=               # optional, separate model for async extraction
ROUTER_ENABLED=                    # optional, toggle deterministic FAQ router
LOG_LEVEL=                         # optional, e.g. debug | info | warn | error

# --- Fieldpulse (optional, integration not yet enabled) ---
FIELDPULSE_API_KEY=
FIELDPULSE_WEBHOOK_SECRET=           # 64-char hex string for HMAC-SHA256 webhook signature verification

# --- Consumer financing (optional, mock until a lender contract exists) ---
WISETACK_API_KEY=                    # Lender API key. Until set, financing uses the deterministic mock provider.
FINANCING_WEBHOOK_SECRET=            # Shared secret for the lender status callback (x-financing-secret). Webhook FAILS CLOSED if unset.

# --- Resend (transactional email) ---
RESEND_API_KEY=                      # Resend API key (re_...). If unset, email jobs are skipped (left pending), never failed.
RESEND_WEBHOOK_SECRET=               # HMAC secret for verifying Resend delivery webhooks (required for delivery-status updates)
