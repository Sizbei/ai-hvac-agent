# --- Required ---
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
AI_API_KEY=sk-...                  # LLM provider key (OpenAI-compatible)
AI_BASE_URL=                       # OpenAI-compatible base URL (e.g. DashScope endpoint)
AI_MODEL=                          # chat model id (DashScope best: qwen-max)
# --- Optional: GLM (z.ai) for the super-admin model switcher ---
# Configure these to make "GLM-4.6 (z.ai)" selectable in Settings → Integrations
# (super-admin only). If GLM_API_KEY is unset, selecting GLM silently falls back
# to the default model — a customer turn is never broken by a missing key.
GLM_API_KEY=                       # z.ai API key (leave blank to disable GLM)
GLM_BASE_URL=https://api.z.ai/api/paas/v4   # OpenAI-compatible base URL for z.ai
GLM_MODEL=glm-4.6                  # GLM model id
ENCRYPTION_KEY=64-hex-chars-here   # PII encryption + dedupe blind-index HMAC (openssl rand -hex 32)
AUTH_SECRET=generate-a-32-char-random-string-here  # min 32 chars (openssl rand -hex 32)
CRON_SECRET=generate-a-random-secret-for-cron-auth
# REQUIRED — absolute public base URL of this deployment. Validated at boot
# (CSRF origin checks, TTS audio links, widget embed). e.g. https://app.example.com
NEXT_PUBLIC_APP_URL=
# First-admin bootstrap for the super-admin seed (npm run db:seed:super-admin).
# Set these to make YOURSELF the Google-only owner of a fresh instance instead
# of the demo default. Falls back to the demo owner when unset.
SUPER_ADMIN_EMAIL=                  # e.g. you@example.com (Google-only login)
SUPER_ADMIN_NAME=                   # e.g. Your Name
# Comma-separated emails of PLATFORM admins who may provision new tenant orgs
# (separate from per-org super_admin). Leave blank to disable tenant provisioning.
PLATFORM_ADMIN_EMAILS=
PLATFORM_ORG_ID=                  # org id of the platform-owner org; platform-admin access requires BOTH this AND an allowlisted email (fails closed if unset)
# Hard cap on the total number of organizations that can be provisioned. This is
# the authoritative ceiling (the per-instance rate limiter can't throttle across
# serverless instances). Blank, 0, or invalid falls back to 100 (NOT unlimited).
PLATFORM_MAX_ORGS=100
NODE_ENV=development

# --- Twilio (phone agent) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=               # the voice-capable number incoming calls arrive on
TWILIO_SPEECH_TIMEOUT=             # optional, seconds Twilio waits for speech

# --- Voice (optional) ---
ELEVENLABS_API_KEY=                # premium phone TTS; falls back to Polly <Say> if unset
ELEVENLABS_VOICE_ID=               # optional, defaults to "Brian"
ELEVENLABS_MODEL_ID=               # optional, defaults to eleven_turbo_v2_5
VOICE_PROVIDER=                    # optional, force "elevenlabs" or "polly"
TWILIO_VOICE=                      # optional Polly voice override (used only when no ElevenLabs key)

# --- Dispatch routing / travel time (optional) ---
# Off by default: dispatch scores travel by straight-line distance (haversine).
# Set a provider + key to score by real road drive-time instead (see docs/DISPATCH.md).
ROUTING_PROVIDER=                  # none (default) | ors | mapbox | google
ORS_API_KEY=                       # OpenRouteService key (free tier) — used when ROUTING_PROVIDER=ors
# MAPBOX_TOKEN=                    # used when ROUTING_PROVIDER=mapbox (adapter TBD)
# GOOGLE_MAPS_KEY=                 # used when ROUTING_PROVIDER=google (adapter TBD)

# --- Google (optional) ---
GOOGLE_CLIENT_ID=                  # admin Google sign-in + Calendar integration
GOOGLE_CLIENT_SECRET=
GOOGLE_OIDC_REDIRECT_URI=          # OIDC login callback, e.g. https://app.example.com/api/auth/google/callback
GOOGLE_OIDC_SIGNUP_REDIRECT_URI=   # self-serve signup callback, e.g. https://app.example.com/api/auth/signup/callback — MUST be registered as an authorized redirect URI in the Google Cloud OAuth console; the signup routes 404 until this is set
GOOGLE_REDIRECT_URI=               # Calendar OAuth callback

# --- Housecall Pro (optional; single-tenant fallback — per-org keys via the
#     admin Connect flow take precedence. Mock-first / not yet live-verified.) ---
HOUSECALL_API_KEY=
HOUSECALL_WEBHOOK_SECRET=

# --- Attachment storage: Cloudflare R2 / S3 (optional) ---
# Photo/file attachments. All blank → attachment uploads are disabled and the
# rest of the app runs normally; the R2 client only throws if an upload is
# actually attempted without these.
R2_PUBLIC_URL=                     # public base URL for stored attachments
R2_ACCOUNT_ID=                     # Cloudflare R2 account id
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=                       # optional, defaults to the account-based URL

# --- Misc (optional) ---
AI_EXTRACTION_MODEL=               # optional, separate model for async extraction
ROUTER_ENABLED=                    # optional, toggle deterministic FAQ router
LOG_LEVEL=                         # optional, e.g. debug | info | warn | error

# --- Fieldpulse (optional; single-tenant fallback — per-org keys via the admin
#     Connect flow take precedence. Read path live-verified; see docs/INTEGRATIONS.md.) ---
FIELDPULSE_API_KEY=
FIELDPULSE_WEBHOOK_SECRET=           # 64-char hex string for HMAC-SHA256 webhook signature verification
# Live smoke harness only (npm run smoke:fieldpulse): optional ids to exercise invoice pulls
FIELDPULSE_SMOKE_INVOICE_ID=
FIELDPULSE_SMOKE_JOB_ID=

# --- Consumer financing (optional, mock until a lender contract exists) ---
WISETACK_API_KEY=                    # Lender API key. Until set, financing uses the deterministic mock provider.
FINANCING_WEBHOOK_SECRET=            # Shared secret for the lender status callback (x-financing-secret). Webhook FAILS CLOSED if unset.

# --- SaaS billing (Stage 10) + customer payments (Stage 11) — Stripe ---
# STRIPE_SECRET_KEY is shared by both. Until the real Stripe adapters land, the
# SaaS-billing AND payment seams still use the MOCK even when this is set (they
# log a LOUD warning) — NO real charges/subscriptions are processed.
STRIPE_SECRET_KEY=                   # Stripe secret key (sk_...). Used by SaaS billing (Stage 10) and customer payments (Stage 11).
# Stripe Billing Price ids per plan (commented until real Stripe Billing lands;
# the StripeBillingProvider will map plan id -> price id from these).
# STRIPE_BILLING_PRICE_STARTER=      # price_... for the Starter plan
# STRIPE_BILLING_PRICE_PRO=          # price_... for the Pro plan
# STRIPE_BILLING_PRICE_SCALE=        # price_... for the Scale plan
SAAS_BILLING_WEBHOOK_SECRET=         # HMAC secret for the SaaS-subscription webhook (x-saas-billing-signature). Webhook FAILS CLOSED if unset.

# --- Resend (transactional email) ---
RESEND_API_KEY=                      # Resend API key (re_...). If unset, email jobs are skipped (left pending), never failed.
RESEND_WEBHOOK_SECRET=               # HMAC secret for verifying Resend delivery webhooks (required for delivery-status updates)

# --- Reviews / reputation (optional, mock until a public-review URL is set) ---
GOOGLE_REVIEW_URL=                   # Public Google/Yelp review deep-link. Until set, the review seam returns a mock placeholder URL.

# --- Sentry error tracking (optional, fully degrade-safe) ---
# With NEITHER DSN set, the app builds and runs exactly as before: Sentry init
# no-ops, the build plugin is skipped, and all Sentry.* calls are inert.
SENTRY_DSN=                          # server/edge DSN. Unset = no server error capture (no-op).
NEXT_PUBLIC_SENTRY_DSN=              # browser DSN. Unset = no client error capture (no-op).
# Source-map upload (optional; only used at build time when SENTRY_DSN is set).
# Without these, runtime capture still works — only readable stack traces need them.
SENTRY_ORG=                          # Sentry org slug
SENTRY_PROJECT=                      # Sentry project slug
SENTRY_AUTH_TOKEN=                   # build-time token for source-map upload (CI secret)
SENTRY_TRACES_SAMPLE_RATE=           # optional 0..1 perf-tracing sample rate (default 0 = off)

# --- QuickBooks / accounting export (optional, CSV-only until both are set) ---
# Until BOTH are set, the accounting export uses the mock provider (downloadable
# CSV). Setting these alone does NOT sync to QuickBooks — the OAuth adapter is
# not built yet (the export route logs a loud warning when they are present).
# QBO_CLIENT_ID=                     # QuickBooks Online OAuth client id
# QBO_CLIENT_SECRET=                 # QuickBooks Online OAuth client secret
