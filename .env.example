DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
OPENAI_API_KEY=sk-...
ENCRYPTION_KEY=64-hex-chars-here
AUTH_SECRET=generate-a-32-char-random-string-here
CRON_SECRET=generate-a-random-secret-for-cron-auth
NODE_ENV=development
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=          # optional, defaults to "Brian"
ELEVENLABS_MODEL_ID=          # optional, defaults to eleven_turbo_v2_5
TWILIO_VOICE=                 # optional Polly override (used only when no ElevenLabs key)
